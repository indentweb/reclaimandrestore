# --- Booking email delivery (optional but recommended) ---
# The site works without these set: booking requests fall back to opening the
# visitor's email app addressed to NEXT_PUBLIC_BOOKING_EMAIL. Set these to have
# requests emailed automatically and silently from the server via Resend.

# Get a free API key at https://resend.com
RESEND_API_KEY=

# Where booking requests are delivered (the business owner's inbox)
BOOKING_EMAIL=owner@example.com

# Public-facing address used for the mailto fallback (no secrets here)
NEXT_PUBLIC_BOOKING_EMAIL=bookings@reclaimandrestore.com

# Optional: verified "from" address on your Resend domain.
# Defaults to Resend's shared onboarding sender if not set.
# BOOKING_FROM_EMAIL=Reclaim & Restore <bookings@yourdomain.com>

# --- Owner photo dashboard (/admin) ---
# Password the owner enters at /admin to upload gallery photos.
# If this is unset, photo uploads are disabled.
ADMIN_PASSWORD=change-me
